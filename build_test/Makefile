	$(MAKE) $(MAKESILENT) -f CMakeFiles/shogi_core.dir/build.make CMakeFiles/shogi_core.dir/src/text_util.cpp.s
.PHONY : src/text_util.cpp.s

src/usi_protocol.o: src/usi_protocol.cpp.o
.PHONY : src/usi_protocol.o

# target to build an object file
src/usi_protocol.cpp.o:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/kishi-to-classic.dir/build.make CMakeFiles/kishi-to-classic.dir/src/usi_protocol.cpp.o
.PHONY : src/usi_protocol.cpp.o

src/usi_protocol.i: src/usi_protocol.cpp.i
.PHONY : src/usi_protocol.i

