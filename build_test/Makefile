	$(MAKE) $(MAKESILENT) -f CMakeFiles/kishi-to-classic.dir/build.make CMakeFiles/kishi-to-classic.dir/src/usi_protocol.cpp.i
.PHONY : src/usi_protocol.cpp.i

src/usi_protocol.s: src/usi_protocol.cpp.s
.PHONY : src/usi_protocol.s

